// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid()) @db.Uuid
  name String @db.VarChar(100)
  email String @unique @db.VarChar(128)
  phone String? @db.VarChar(128)
  password String @db.VarChar(255)
  isActive Boolean @default(true) @db.Boolean @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  refreshTokens RefreshToken[]
  emailAccounts EmailAccount[]
  @@map("users")
  @@index([email])
  @@index([phone])
}

model RefreshToken {
  id String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid @map("user_id")
  token String @db.Text @unique
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean @db.Boolean @default(false) @map("is_revoked")

  userAgent String? @db.VarChar(100) @map("user_agent")
  ipAddress String? @db.VarChar(100) @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@index([userId,token]) 
}

model EmailAccount {
  id String @id @db.Uuid @default(uuid())
  userId String @db.Uuid @map("user_id")
  emailAddress String @db.VarChar(150) @unique @map("email_address")
  appPassword String? @db.Text @map("app_password")
  authId String? @db.Text @map("auth_id")
  accessToken String? @db.Text @map("access_token")
  refreshToken String? @db.Text @map("refresh_token")
  smtpHost String? @db.VarChar(100) @map("smtp_host")
  smtpPort Int? @db.Integer @map("smtp_port")
  imapHost String? @db.VarChar(100) @map("imap_host")
  imapPort Int? @db.Integer @map("imap_port")
  provider String @db.VarChar(80) @default("custom") @map("provider")
  isActive Boolean @db.Boolean @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_accounts")
}